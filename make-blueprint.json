                    "name": "name",
                    "type": "text",
                    "label": "Name",
                    "required": true,
                    "validate": {
                      "pattern": "^[-!#$%&'*+.^_`|~0-9A-Za-z]+$"
                    }
                  },
                  {
                    "name": "value",
                    "type": "text",
                    "label": "Value"
                  }
                ],
                "type": "collection",
                "label": "Header"
              },
              "type": "array",
              "label": "Headers"
            },
            {
              "name": "queryParameters",
              "spec": {
                "name": "value",
                "spec": [
                  {
                    "name": "name",
                    "type": "text",
                    "label": "Name",
                    "required": true
                  },
                  {
                    "name": "value",
                    "type": "text",
                    "label": "Value"
                  }
                ],
                "type": "collection",
                "label": "Parameter"
              },
              "type": "array",
              "label": "Query parameters"
            }
          ],
          "restore": {
            "expect": {
              "headers": {
                "mode": "chose"
              },
              "shareCookies": {
                "mode": "chose"
              },
              "queryParameters": {
                "mode": "chose"
              },
              "stopOnHttpError": {
                "mode": "chose"
              }
            },
            "parameters": {
              "authenticationType": {
                "label": "No authenticationUse when no credentials are required for the request."
              }
            }
