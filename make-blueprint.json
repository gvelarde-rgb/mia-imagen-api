        "version": 4,
        "metadata": {
          "expect": [
            {
              "name": "url",
              "type": "url",
              "label": "URL",
              "required": true
            },
            {
              "name": "stopOnHttpError",
              "type": "boolean",
              "label": "Return error if HTTP request fails",
              "required": true
